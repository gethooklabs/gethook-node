{
  "name": "@gethook/node",
  "version": "0.1.0",
  "description": "Node.js / TypeScript SDK for the GetHook API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "generate": "openapi-typescript openapi.yaml -o src/schema.gen.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "openapi-typescript": "^7.0.0"
  },
  "license": "MIT"
}
